# Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini Image Generation Model (optional, defaults to imagen-3.0-generate-001)
# GEMINI_IMAGE_MODEL=imagen-3.0-generate-001

# AWS Credentials for Terraform (if needed)
AWS_ACCESS_KEY=your_aws_access_key_here
AWS_SECRET_KEY=your_aws_secret_key_here

# AWS Credentials for S3 Upload
UPLOADER_AWS_ACCESS_KEY=your_aws_access_key_here
UPLOADER_AWS_SECRET_KEY=your_aws_secret_key_here
UPLOADER_S3_BUCKET=your_bucket_name_here
